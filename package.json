{
  "name": "client",
  "version": "0.0.0",
  "main": "electron/out/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:yandex": "cross-env VITE_PLATFORM_API=yandex vite",
    "dev:local": "cross-env VITE_PLATFORM_API=local vite",
    "dev:desktop": "cross-env VITE_PLATFORM_API=desktop electron-vite dev",
    "dev:steam": "cross-env STEAM_APP_ID=4927190 VITE_PLATFORM_API=steam electron-vite dev",
    "build": "vite build",
    "build:yandex": "cross-env VITE_PLATFORM_API=yandex vite build",
    "build:local": "cross-env VITE_PLATFORM_API=local vite build",
    "build:desktop": "cross-env VITE_PLATFORM_API=desktop electron-vite build",
    "build:steam": "cross-env STEAM_APP_ID=4927190 VITE_PLATFORM_API=steam electron-vite build",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "dist:steam:mac": "npm run build:steam && electron-builder --mac --dir --config electron-builder.steam.json",
    "dist:steam:windows": "npm run build:steam && electron-builder --win --dir --config electron-builder.steam.json",
    "preview": "vite preview",
    "deploy": "npm run build:local && ssh root@orion7.skybug.ru 'mkdir -p /var/www/orion7/dist' && rsync -avz --delete dist/ root@orion7.skybug.ru:/var/www/orion7/dist/",
    "deploy:steam:mac": "npm run dist:steam:mac && steamcmd +login pokrov1991 +run_app_build steamworks/scripts/app_build_4927190_mac.vdf +quit",
    "deploy:steam:windows": "npm run dist:steam:windows && \"D:\\Games\\steamcmd\\steamcmd.exe\" +login pokrov1991 +run_app_build \"%CD%\\steamworks\\scripts\\app_build_4927190_windows.vdf\" +quit",
    "server:deploy": "npm --prefix server run deploy",
    "server:start": "npm --prefix server start",
    "server:migrate": "npm --prefix server run migrate",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.18",
    "@mui/material": "^5.15.18",
    "@mui/styled-engine-sc": "^6.0.0-alpha.18",
    "@reduxjs/toolkit": "^2.2.5",
    "@yandex-games/sdk-dev-proxy": "^0.0.1",
    "classnames": "^2.5.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.2",
    "eslint-config-prettier": "^8.5.0",
    "express": "^4.19.2",
    "prettier": "^2.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.0.2",
    "react-svg": "^16.1.34",
    "serialize-javascript": "^6.0.1",
    "steamworks.js": "^0.4.0",
    "styled-components": "^6.1.11",
    "vite": "^4.4.9"
  },
  "devDependencies": {
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@types/react-redux": "^7.1.33",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^8.23.0",
    "identity-obj-proxy": "^3.0.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.2",
    "vite-plugin-webp-compress": "^1.1.4",
    "whatwg-fetch": "^3.6.20"
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "license": "MIT",
  "build": {
    "appId": "com.orion7.game",
    "productName": "Orion-7",
    "directories": {
      "output": "electron/release/desktop",
      "buildResources": "electron/build"
    },
    "files": [
      "electron/out/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    }
  }
}
